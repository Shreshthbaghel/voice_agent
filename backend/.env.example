# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
VOICE_PROVIDER=deepgram

# MetricAI cloud proxy (required for metering)
METRICAI_API_KEY=your_metricai_api_key
# Optional override (default https://proxy.metricai.co.in)
METRICAI_PROXY_URL=https://staging-proxy.metricai.co.in
METRICAI_AGENT_ID=voice-medicine-assistant
METRICAI_USER_ID=voice-user
# LiveKit voice is not auto-instrumented. STT/TTS dashboard rows use client-side track().
# Staging Deepgram proxy currently 500s — Deepgram stays direct even when this is true.
METRICAI_ROUTE_VOICE=true

# OpenAI (BYOK via MetricAI)
OPENAI_API_KEY=your_openai_api_key
LLM_MODEL=gpt-4o-mini

# Speech providers — pairs only (BYOK via MetricAI)
DEEPGRAM_API_KEY=your_deepgram_api_key
SARVAM_API_KEY=your_sarvam_api_key
ELEVENLABS_API_KEY=

# Database
DATABASE_URL=sqlite:///./voicemed.db

# Retrieval
CHROMA_PERSIST_DIR=./data/chroma
SIMILARITY_THRESHOLD=0.75
KNOWLEDGE_TTL_DAYS=30

# App
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=INFO
